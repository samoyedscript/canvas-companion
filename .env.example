# Canvas LMS
CC_CANVAS_BASE_URL=https://canvas.instructure.com
CC_CANVAS_API_TOKEN=your_canvas_token_here

# Google Drive OAuth
CC_GOOGLE_CREDENTIALS_PATH=credentials/credentials.json
CC_GOOGLE_TOKEN_PATH=credentials/token.json
CC_DRIVE_ROOT_FOLDER_NAME=Canvas Companion

# Telegram
CC_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
CC_TELEGRAM_CHAT_ID=your_chat_id_here

# Scheduler
CC_SYNC_INTERVAL_MINUTES=30

# Database
CC_DB_PATH=canvas_companion.db

# Logging
CC_LOG_LEVEL=INFO

# Gemini API (optional — required for /prep study pack generation)
# Get your key at https://aistudio.google.com/apikey
CC_GEMINI_API_KEY=your_gemini_api_key_here
CC_GEMINI_MODEL=gemini-2.5-flash
